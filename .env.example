# Discord application
BOT_TOKEN=replace_with_your_discord_bot_token
BOT_DISPLAY_NAME=Jangle
BOT_PREFIX=!

# Strongly recommended: restrict Jangle to your server and test channels.
# IDs are comma-separated. Names are optional fallbacks and are case-insensitive.
DISCORD_ALLOWED_GUILD_IDS=
DISCORD_TEXT_CHANNEL_IDS=
DISCORD_TEXT_CHANNEL_NAMES=TEST text
DISCORD_VOICE_CHANNEL_IDS=
DISCORD_VOICE_CHANNEL_NAMES=TEST voice
DISCORD_ADMIN_ROLE_IDS=
JANGLE_OWNER_USER_IDS=

# Set one development guild to update slash commands immediately while testing.
DISCORD_DEV_GUILD_ID=

# Text messages in configured channels require Jangle/Hey Jangle by default.
TEXT_REQUIRE_CALL_WORD=true
TEXT_CALL_WORDS=Jangle

# Model provider: lmstudio, ollama, or warlune.
MODEL_PROVIDER=lmstudio

# Leave MODEL_ENDPOINT blank for the provider default:
# LM Studio: http://127.0.0.1:1234/v1
# Ollama:    http://127.0.0.1:11434/v1
MODEL_ENDPOINT=

# Leave blank to select the first available non-embedding model.
# Ollama users will usually set this to an installed tag such as llama3.2.
MODEL_NAME=

# Optional local-server API token. Ollama's local endpoint normally ignores it.
MODEL_API_KEY=
MODEL_REQUEST_TIMEOUT_SECONDS=120

# Optional public web context through a local SearXNG instance.
INTERNET_SEARCH_ENABLED=false
SEARXNG_URL=http://127.0.0.1:8888
SEARCH_MAX_RESULTS=5

# Optional Warlune provider. Used only when MODEL_PROVIDER=warlune.
WARLUNE_PATH=
WARLUNE_CONFIG=
WARLUNE_ENDPOINT=
WARLUNE_MODEL=

# Request concurrency and temporary in-memory history.
MAX_CONCURRENT_REQUESTS=2
EPHEMERAL_HISTORY_TURNS=6
ANSWER_MAX_CHARS=6000

# Test observability. Never enable this without informing channel participants.
JANGLE_TEST_MODE=false
TEST_CONVERSATION_LOG=
TEST_LOG_MAX_MB=10

# Voice input: Discord PCM is transcribed locally and is never saved as audio.
VOICE_WAKE_WORDS=jangle,jengel,jingle,jangel
VOICE_SILENCE_MS=650
VOICE_MIN_MS=250
VOICE_MAX_SECONDS=25
VOICE_RMS_THRESHOLD=200
VOICE_PREROLL_MS=240
VOICE_BARGE_IN_FRAMES=15
VOICE_FOLLOWUP_SECONDS=25
VOICE_TEXT_ECHO=false
WHISPER_MODEL=base.en
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=en

# Voice output. Edge sends generated answer text to Microsoft TTS.
# Use none to disable spoken output.
TTS_PROVIDER=edge
TTS_VOICE=en-US-AriaNeural
TTS_RATE=+5%
TTS_MAX_CHARS=600

# Optional state paths. Blank values use private files under ./data.
TTS_STATE_PATH=
PERSONALITY_STATE_PATH=
IGNORED_SPEAKERS_STATE_PATH=
USER_NOTES_STATE_PATH=
DND_STATE_PATH=

# YouTube music
MUSIC_VOLUME=0.45
MUSIC_MAX_MINUTES=720
MUSIC_QUEUE_MAX=50
PLAYLIST_MAX_TRACKS=25
YOUTUBE_SEARCH_TIMEOUT_SECONDS=30
